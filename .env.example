# Basic Auth (used for admin panel, Traefik dashboard)
# Generate with: echo $(htpasswd -nB admin) | sed -e s/\$/\$\$/g
# Output looks like: admin:$$2y$$05$$abc123...
BASIC_AUTH_USERS=admin:$$2y$$05$$...paste-hash-here...

# PostgreSQL
POSTGRES_USER=nullspace
POSTGRES_PASSWORD=changeme
POSTGRES_DB=nullspace

# GlitchTip
GLITCHTIP_SECRET_KEY=changeme-generate-a-random-string
# Dev: http://errors.localhost:8000  |  Prod: https://errors.beshtawi.online
GLITCHTIP_DOMAIN=http://errors.localhost:8000
