# =========================================================
# Lite mode toggle
# docker-compose reads COMPOSE_PROFILES natively. Services tagged with
# `profiles: ["full"]` (currently dogeclaw + dogeclaw-migrations) only
# start when "full" is active. Set to empty (or comment out) for lite mode.
# =========================================================
COMPOSE_PROFILES=full

# =========================================================
# Public domain (single source of truth)
# All Traefik Host rules and per-service URLs derive from this.
# Dev uses *.localhost regardless of this value.
# =========================================================
DOMAIN=datenflow.de

# =========================================================
# Shared credentials (defined once, referenced below)
# =========================================================
# Generate with: openssl rand -base64 24
DB_USER=nullspace
DB_PASSWORD=changeme
DB_NAME=nullspace
DB_HOST=postgres
DB_PORT=5432

# =========================================================
# Basic Auth (bcrypt hash — note the doubled $$ for docker-compose)
# Generate with: htpasswd -nbB admin 'your-password' | sed -e 's/\$/\$\$/g'
# =========================================================
BASIC_AUTH_USERS=admin:$$2y$$05$$...paste-hash-here...

# =========================================================
# PostgreSQL
# =========================================================
POSTGRES_USER=${DB_USER}
POSTGRES_PASSWORD=${DB_PASSWORD}
POSTGRES_DB=${DB_NAME}

# =========================================================
# GlitchTip
# Generate SECRET_KEY with: openssl rand -hex 32
# GLITCHTIP_DOMAIN is set per-environment in compose (derived from DOMAIN in prod).
# =========================================================
GLITCHTIP_SECRET_KEY=changeme-generate-a-random-string

# =========================================================
# DogeClaw Agent
# Generate WEB_PASSWORD with: openssl rand -base64 18
# Generate WEB_SECRET with:   openssl rand -hex 32
# =========================================================
# Ollama runs in a separate container (start manually with: docker compose --profile manual up -d ollama)
DOGECLAW_OLLAMA_URL=http://ollama:11434
# Model pulled by Ollama on first start
OLLAMA_DEFAULT_MODEL=gemma4:e2b
DOGECLAW_PORT=3000

DOGECLAW_WEB_USER=admin
DOGECLAW_WEB_PASSWORD=changeme
DOGECLAW_WEB_SECRET=changeme-generate-a-random-string

# DogeClaw connects to the dedicated `dogeclaw` database (created by
# scripts/cluster-init.sql) using the cluster's main POSTGRES_USER
# credentials. The compose file passes POSTGRES_USER, POSTGRES_PASSWORD,
# POSTGRES_DB=dogeclaw, POSTGRES_HOST=postgres, POSTGRES_PORT=5432
# directly, so no per-service URL needs to live in .env.

# Telegram: polling (dev) or webhook (prod)
# Bots are configured via the admin UI (stored in DB)
# Webhook URL is derived from DOMAIN in prod compose; leave unset in dev.
DOGECLAW_TELEGRAM_MODE=polling

# =========================================================
# Telebot — anonymous chat Telegram bot
# Connects to the `telebot` database (provisioned by postgres-init) using
# the cluster's main POSTGRES_USER credentials. Bot token / webhook URL /
# AI provider are configured at runtime via /admin/settings, not here.
# Generate SESSION_SECRET with: openssl rand -hex 32
# =========================================================
TELEBOT_ADMIN_USERNAME=admin
TELEBOT_ADMIN_PASSWORD=changeme
TELEBOT_SESSION_SECRET=changeme-generate-a-random-string

# Auto-match scheduler: when enabled, the bot pairs queued users on the
# given cron schedule, but only if they've waited at least MIN_WAIT
# seconds. Set ENABLED=false to disable the scheduler entirely. The cron
# value MUST be quoted because it contains spaces.
AUTO_MATCH_ENABLED=true
AUTO_MATCH_CRON="* * * * *"
AUTO_MATCH_MIN_WAIT=30

# =========================================================
# Mail / SMTP — consumed by kiwelt
# Defaults below target the local mailpit container (added by
# docker-compose.override.yml). Mailpit accepts any credentials and never
# sends mail off-box; its web UI lives at http://localhost:8025.
# In prod, the VPS .env replaces these with real SMTP credentials.
# =========================================================
SMTP_HOST=mail
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Datenflow Dev <dev@datenflow.local>
MAIL_TO_CONTACT=dev@datenflow.local
MAIL_TO_KARRIERE=dev@datenflow.local
