# Basic Auth (used for admin panel, Traefik dashboard)
# Generate with: echo $(htpasswd -nB admin) | sed -e s/\$/\$\$/g
# Output looks like: admin:$$2y$$05$$abc123...
BASIC_AUTH_USERS=admin:$$2y$$05$$...paste-hash-here...

# PostgreSQL
POSTGRES_USER=nullspace
POSTGRES_PASSWORD=changeme
POSTGRES_DB=nullspace

# GlitchTip
GLITCHTIP_SECRET_KEY=changeme-generate-a-random-string
# Dev: http://errors.localhost:8000  |  Prod: https://errors.beshtawi.online
GLITCHTIP_DOMAIN=http://errors.localhost:8000

# DogeClaw Agent
DOGECLAW_OLLAMA_URL=http://127.0.0.1:11434
DOGECLAW_MODEL=gemma4:e2b
DOGECLAW_THINK=false
DOGECLAW_PORT=3000
DOGECLAW_WEB_USER=admin
DOGECLAW_WEB_PASSWORD=changeme
DOGECLAW_WEB_SECRET=changeme-generate-a-random-string
# Database (optional, uses the shared PostgreSQL)
DOGECLAW_DATABASE_URL=postgres://nullspace:changeme@postgres:5432/nullspace
# Telegram: polling (dev) or webhook (prod)
# Telegram bots are configured via the admin UI (stored in DB)
DOGECLAW_TELEGRAM_MODE=polling
# Webhook URL (prod only, when DOGECLAW_TELEGRAM_MODE=webhook)
DOGECLAW_WEBHOOK_URL=https://dogeclaw.beshtawi.online
