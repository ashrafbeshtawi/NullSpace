# Basic Auth (used for admin panel, Traefik dashboard, Dozzle)
# Generate ADMIN_PASSWORD_HASH with: echo $(htpasswd -nB admin) | sed -e s/\\$/\\$\\$/g
ADMIN_USER=admin
ADMIN_PASSWORD_HASH=$$2y$$05$$...hashed...password...here...

# PostgreSQL
POSTGRES_USER=nullspace
POSTGRES_PASSWORD=changeme
POSTGRES_DB=nullspace

# GlitchTip
GLITCHTIP_SECRET_KEY=changeme-generate-a-random-string
