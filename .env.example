# =========================================================
# Shared credentials (defined once, referenced below)
# =========================================================
# Generate with: openssl rand -base64 24
DB_USER=nullspace
DB_PASSWORD=changeme
DB_NAME=nullspace
DB_HOST=postgres
DB_PORT=5432

# =========================================================
# Basic Auth (bcrypt hash — note the doubled $$ for docker-compose)
# Generate with: htpasswd -nbB admin 'your-password' | sed -e 's/\$/\$\$/g'
# =========================================================
BASIC_AUTH_USERS=admin:$$2y$$05$$...paste-hash-here...

# =========================================================
# PostgreSQL
# =========================================================
POSTGRES_USER=${DB_USER}
POSTGRES_PASSWORD=${DB_PASSWORD}
POSTGRES_DB=${DB_NAME}

# =========================================================
# GlitchTip
# Generate SECRET_KEY with: openssl rand -hex 32
# =========================================================
GLITCHTIP_SECRET_KEY=changeme-generate-a-random-string
# Dev: http://errors.localhost:8000  |  Prod: https://errors.beshtawi.online
GLITCHTIP_DOMAIN=http://errors.localhost:8000

# =========================================================
# DogeClaw Agent
# Generate WEB_PASSWORD with: openssl rand -base64 18
# Generate WEB_SECRET with:   openssl rand -hex 32
# =========================================================
# Ollama runs in a separate container (start manually with: docker compose --profile manual up -d ollama)
DOGECLAW_OLLAMA_URL=http://ollama:11434
# Model pulled by Ollama on first start
OLLAMA_DEFAULT_MODEL=gemma4:e2b
DOGECLAW_PORT=3000

DOGECLAW_WEB_USER=admin
DOGECLAW_WEB_PASSWORD=changeme
DOGECLAW_WEB_SECRET=changeme-generate-a-random-string

# Admin DB (full access — web UI manages agents/channels/models)
DOGECLAW_ADMIN_DATABASE_URL=postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}
# Agent DB (restricted — read-only on config, can create/manage own tables)
# In prod, use the dogeclaw user: postgres://dogeclaw:dogeclaw-agent-pw@postgres:5432/nullspace
DOGECLAW_DATABASE_URL=postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# Telegram: polling (dev) or webhook (prod)
# Bots are configured via the admin UI (stored in DB)
DOGECLAW_TELEGRAM_MODE=polling
# Webhook URL (prod only, when DOGECLAW_TELEGRAM_MODE=webhook)
DOGECLAW_WEBHOOK_URL=https://dogeclaw.beshtawi.online
